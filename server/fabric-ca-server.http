@baseUrl = http://localhost:3000
@containerName = boot-ca
@adminUsername = tls-admin
@adminPassword = tls-adminpw

### Init CA in Docker container
POST {{baseUrl}}/api/fabric-ca-server/init
Content-Type: application/json

{
  "containerName": "{{containerName}}",
  "orgUser": "{{adminUsername}}",
  "orgPassword": "{{adminPassword}}"
}

### Start CA in Docker container
POST {{baseUrl}}/api/fabric-ca-server/start
Content-Type: application/json

{
  "containerName": "{{containerName}}",
  "orgUser": "{{adminUsername}}",
  "orgPassword": "{{adminPassword}}"
}

### Negative test: missing containerName should return 400
POST {{baseUrl}}/api/fabric-ca-server/init
Content-Type: application/json

{
  "orgUser": "{{adminUsername}}",
  "orgPassword": "{{adminPassword}}"
}
